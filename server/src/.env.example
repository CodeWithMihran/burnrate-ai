# Local backend server port
PORT=5000

# Public backend origin used for share pages and email links
APP_URL=http://localhost:5000

# Public frontend origin used for share-page redirects
FRONTEND_APP_URL=http://localhost:5173

# Optional locally. If blank, the server falls back to local file-backed storage.
MONGO_URI=

# Optional locally. If blank, AI summaries fall back gracefully.
ANTHROPIC_API_KEY=

# Optional locally. If blank, transactional email is skipped.
RESEND_API_KEY=
EMAIL_FROM=
